// Jenkinsfile for building OpenClaw custom image with stable BuildKit service
pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins: agent
spec:
  containers:
  - name: buildctl
    image: harbor.clusters.zjusct.io/docker.io/moby/buildkit:latest-rootless
    command:
    - sleep
    args:
    - 99d
    env:
    - name: BUILDKIT_HOST
      value: "tcp://buildkitd.buildkit.svc.cluster.local:1234"
    - name: DOCKER_CONFIG
      value: "/registry-config"
    volumeMounts:
    - name: docker-config
      mountPath: /registry-config
      readOnly: true
  volumes:
  - name: docker-config
    secret:
      secretName: harbor-registry-secret
      items:
      - key: .dockerconfigjson
        path: config.json
'''
        }
    }

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Image tag to build')
        string(name: 'REGISTRY', defaultValue: 'harbor.clusters.zjusct.io', description: 'Container registry')
    }

    environment {
        BASE_IMAGE = 'harbor.clusters.zjusct.io/ghcr.io/openclaw/openclaw'
        BASE_TAG = '2026.2.9'
        TARGET_IMAGE = "${params.REGISTRY}/dev/openclaw"
        GIT_COMMIT_SHORT = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
    }

    stages {
        stage('Prepare') {
            steps {
                script {
                    // Use git commit SHA if IMAGE_TAG is 'latest'
                    env.FINAL_TAG = params.IMAGE_TAG == 'latest' ? env.GIT_COMMIT_SHORT : params.IMAGE_TAG
                    echo "Building ${env.TARGET_IMAGE}:${env.FINAL_TAG}"
                }
            }
        }

        stage('Build and Push') {
            steps {
                container('buildctl') {
                    sh """
                        # Check connection to BuildKit daemon
                        echo "Connecting to BuildKit service at \${BUILDKIT_HOST}"
                        buildctl debug workers

                        # Build and push the image
                        buildctl build \
                            --frontend dockerfile.v0 \
                            --local context=dev/openclaw/build \
                            --local dockerfile=dev/openclaw/build \
                            --opt filename=Dockerfile \
                            --opt build-arg:OPENCLAW_VERSION=${env.BASE_TAG} \
                            --output type=image,name=${env.TARGET_IMAGE}:${env.FINAL_TAG},push=true \
                            --output type=image,name=${env.TARGET_IMAGE}:latest,push=true \
                            --export-cache type=inline \
                            --import-cache type=registry,ref=${env.TARGET_IMAGE}:buildcache
                    """
                }
            }
        }

        stage('Verify') {
            steps {
                echo "Image built and pushed successfully:"
                echo "  ${env.TARGET_IMAGE}:${env.FINAL_TAG}"
                echo "  ${env.TARGET_IMAGE}:latest"
            }
        }
    }

    post {
        success {
            echo "Build completed successfully"
        }
        failure {
            echo "Build failed"
        }
    }
}
