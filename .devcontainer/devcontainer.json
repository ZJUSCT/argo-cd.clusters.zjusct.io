{
  "name": "ZJUSCT K8S Dev Container",
  "dockerComposeFile": "compose.yml",
  "service": "devcontainer",
  "mounts": [
    {
      "type": "bind",
      "source": "/dev/kvm",
      "target": "/dev/kvm"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "editorconfig.editorconfig"
      ]
    }
  }
}
