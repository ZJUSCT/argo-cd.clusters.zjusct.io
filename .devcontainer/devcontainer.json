// https://containers.dev/implementors/json_reference/
{
  "name": "argo-cd.clusters.zjusct.io",
  "image": "ghcr.io/zjusct/argo-cd.clusters.zjusct.io:latest",
  "init": true,
  "shutdownAction": "none",
  // enable this for packer KVM
  // "privileged": true,
  // "mounts": [
  //   "source=/dev/kvm,target=/dev/kvm,type=bind"
  // ],
  "containerEnv": {
    // persist configs under workspace
    "KUBECONFIG": "${containerWorkspaceFolder}/.kube/config",
    "OPENCODE_CONFIG_DIR": "${containerWorkspaceFolder}/.opencode",
    "CODEX_HOME": "${containerWorkspaceFolder}/.codex"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "editorconfig.editorconfig",
        "iliazeus.vscode-ansi",
        "foxundermoon.shell-format",
        "timonwong.shellcheck",
        "ms-python.python"
      ]
    }
  }
}
