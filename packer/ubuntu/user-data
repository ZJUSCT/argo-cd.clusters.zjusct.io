# https://cloudinit.readthedocs.io/en/stable/reference/modules.html#apt-configure
apt:
  primary:
    - arches: [default]
      uri: https://mirrors.zju.edu.cn/ubuntu/
  sources:
    # 先从官方源获得公钥，然后使用 gpg --show-keys <key_file> 获得公钥的 keyid 填入
    docker:
      keyid: 9DC858229FC7DD38854AE2D88D81803C0EBFCD88 # https://mirrors.zju.edu.cn/docker-ce/linux/ubuntu/gpg
      keyserver: hkps://keyserver.ubuntu.com/
      source: deb [signed-by=$KEY_FILE] https://mirrors.zju.edu.cn/docker-ce/linux/ubuntu $RELEASE stable
    kubernetes:
      keyid: DE15B14486CD377B9E876E1A234654DA9A296436 # https://pkgs.k8s.io/core:/stable:/v1.35/deb/Release.key
      keyserver: hkps://keyserver.ubuntu.com/
      source: deb [signed-by=$KEY_FILE] https://mirrors.tuna.tsinghua.edu.cn/kubernetes/core:/stable:/v1.35/deb/ /
# https://cloudinit.readthedocs.io/en/stable/reference/modules.html#package-update-upgrade-install
packages:
  # basic
  - apt-transport-https
  - ca-certificates
  # domain
  - freeipa-client
  # utils
  - tmux
  - htop
  - btop
  - python3-full
  - python3-venv
  - jq
  - yq
  # network
  - ethtool
  - tshark
  - curl
  - wget
  - rsync
  - iperf3
  - nmap
  # disk&filesystem
  - hdparm
  - smartmontools
  - nvme-cli
  - squashfs-tools
  - diffutils
  # oob
  - ipmitool
  - redfishtool
  # dev
  - git
  - cmake
  - build-essential
  # docker
  - docker-ce
  - docker-ce-cli
  - containerd.io
  - docker-buildx-plugin
  - docker-compose-plugin
  # k8s
  - kubectl
  - kubelet
  - kubeadm
  # systemd
  - systemd-coredump
  - systemd-resolved
  - systemd-timesyncd
# https://cloudinit.readthedocs.io/en/stable/reference/modules.html#package-update-upgrade-install
package_update: true
package_upgrade: true

timezone: "Asia/Shanghai"
# https://cloudinit.readthedocs.io/en/latest/reference/modules.html#set-hostname
preserve_hostname: true
