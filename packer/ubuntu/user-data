# https://cloudinit.readthedocs.io/en/stable/reference/modules.html#apt-configure
apt:
  # http_proxy: http://172.28.0.3:8080
  # https_proxy: http://172.28.0.3:8080
  primary:
    - arches: [default]
      uri: https://mirrors.zju.edu.cn/ubuntu/
  sources:
    # 先从官方源获得公钥，然后使用 gpg --show-keys <key_file> 获得公钥的 keyid 填入
    docker:
      keyid: 9DC858229FC7DD38854AE2D88D81803C0EBFCD88 # https://mirrors.zju.edu.cn/docker-ce/linux/ubuntu/gpg
      keyserver: hkps://keyserver.ubuntu.com/
      source: deb [signed-by=$KEY_FILE] https://mirrors.zju.edu.cn/docker-ce/linux/ubuntu $RELEASE stable
    kubernetes:
      keyid: DE15B14486CD377B9E876E1A234654DA9A296436 # https://pkgs.k8s.io/core:/stable:/v1.35/deb/Release.key
      keyserver: hkps://keyserver.ubuntu.com/
      source: deb [signed-by=$KEY_FILE] https://mirrors.tuna.tsinghua.edu.cn/kubernetes/core:/stable:/v1.35/deb/ /
    nvidia:
      keyid: EB693B3035CD5710E231E123A4B469963BF863CC # https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-archive-keyring.gpg
      keyserver: hkps://keyserver.ubuntu.com/
      source: deb [signed-by=$KEY_FILE] https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/ /
    doca:
      keyid: CAE649B3B3929F8470D4D33BA024F6F0E6D6A281 # https://linux.mellanox.com/public/repo/doca/GPG-KEY-Mellanox.pub
      keyserver: hkps://keyserver.ubuntu.com/
      source: deb [signed-by=$KEY_FILE] https://linux.mellanox.com/public/repo/doca/latest/ubuntu25.04/x86_64/ ./
