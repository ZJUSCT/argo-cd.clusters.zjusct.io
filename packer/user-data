#cloud-config
# Minimal cloud-init configuration for Packer

# Set password for ubuntu user
users:
  - name: ubuntu
    lock_passwd: false
    # Password: ubuntu
    passwd: $6$wRCAZ7Jx90Q6.57h$EnaX9adttGbiDXqE9wafIKA1wCzYWBg9H7ZBWA2qMK/jXiDm83UGWdkaMwyIkeK/Fl4coaSEY7L9DQ.9N7M2w1
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash

# Allow password authentication
ssh_pwauth: true

# Preserve hostname
preserve_hostname: false

# Packages to install on first boot (optional)
packages:
  - python3

# Run commands on first boot
runcmd:
  - echo "Cloud-init completed" > /var/log/cloud-init-done.log
