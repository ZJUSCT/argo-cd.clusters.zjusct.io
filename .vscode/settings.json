  "editor.formatOnSave": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.associations": {
    "**/templates/**/*.yaml": "go-template", // Helm templates
  },
  "yaml.schemas": {
    "https://json.schemastore.org/yamllint.json": [
      "*.yml",
      "*.yaml"
    ],
  },
}
